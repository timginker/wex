Package: wex
Type: Package
Title: Compute the Exact Observation Weights for the 
    Kalman Filter and Smoother
Version: 0.1.1
Authors@R: c(
    person(
      "Tim", "Ginker",
      email = "timginker@gmail.com",
      role = c("aut", "cre","cph"),
      comment = c(ORCID = "0000-0002-7138-5417")
    )
